<?xml version="1.0" encoding="UTF-8"?>
<!-- productos_vendidos.jrxml — Reporte Productos Más Vendidos -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="productos_vendidos" pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20">

    <parameter name="PERIODO" class="java.lang.String"/>

    <field name="ranking"       class="java.lang.Integer"/>
    <field name="nombre"        class="java.lang.String"/>
    <field name="marca"         class="java.lang.String"/>
    <field name="totalUnidades" class="java.lang.Integer"/>
    <field name="totalIngresos" class="java.lang.Double"/>

    <title>
        <band height="70">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="60" backcolor="#1B5E20"/>
            </rectangle>
            <staticText>
                <reportElement x="0" y="5" width="535" height="30" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[VENTARÁPIDA — PRODUCTOS MÁS VENDIDOS]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="35" width="535" height="20" forecolor="#FFFFFF"/>
                <textElement textAlignment="Center"><font size="11"/></textElement>
                <textFieldExpression><![CDATA["Período: " + $P{PERIODO}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <columnHeader>
        <band height="25">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="25" backcolor="#E8F5E9"/>
            </rectangle>
            <staticText>
                <reportElement x="0"   y="5" width="35"  height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[#]]></text>
            </staticText>
            <staticText>
                <reportElement x="35"  y="5" width="220" height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Producto]]></text>
            </staticText>
            <staticText>
                <reportElement x="255" y="5" width="100" height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Marca]]></text>
            </staticText>
            <staticText>
                <reportElement x="355" y="5" width="80"  height="15"/>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Unidades]]></text>
            </staticText>
            <staticText>
                <reportElement x="435" y="5" width="100" height="15"/>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Ingresos S/]]></text>
            </staticText>
        </band>
    </columnHeader>

    <detail>
        <band height="20">
            <textField>
                <reportElement x="0"   y="2" width="35"  height="15"/>
                <textElement textAlignment="Center"><font size="9" isBold="true"/></textElement>
                <textFieldExpression><![CDATA[$F{ranking}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="35"  y="2" width="220" height="15"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{nombre}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="255" y="2" width="100" height="15"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{marca}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="355" y="2" width="80"  height="15"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{totalUnidades}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="435" y="2" width="100" height="15"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{totalIngresos}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

</jasperReport>
