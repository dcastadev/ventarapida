<?xml version="1.0" encoding="UTF-8"?>
<!-- cierre_caja.jrxml — Reporte Cierre de Caja Diario -->
<jasperReport xmlns="http://jasperreports.sourceforge.net/jasperreports"
              xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
              xsi:schemaLocation="http://jasperreports.sourceforge.net/jasperreports
              http://jasperreports.sourceforge.net/xsd/jasperreport.xsd"
              name="cierre_caja" pageWidth="595" pageHeight="842"
              columnWidth="535" leftMargin="30" rightMargin="30"
              topMargin="20" bottomMargin="20">

    <!-- Parametros recibidos desde Java -->
    <parameter name="FECHA"       class="java.lang.String"/>
    <parameter name="TOTAL_DIA"   class="java.lang.Double"/>
    <parameter name="CANT_VENTAS" class="java.lang.Integer"/>

    <!-- Campos del datasource (Map keys) -->
    <field name="serie"       class="java.lang.String"/>
    <field name="correlativo" class="java.lang.String"/>
    <field name="tipoCompro"  class="java.lang.String"/>
    <field name="cliente"     class="java.lang.String"/>
    <field name="total"       class="java.lang.Double"/>
    <field name="hora"        class="java.lang.String"/>

    <!-- Variable: suma total acumulada -->
    <variable name="totalAcum" class="java.lang.Double"
              calculation="Sum">
        <variableExpression><![CDATA[$F{total}]]></variableExpression>
    </variable>

    <!-- TITULO (aparece solo en la 1ra pagina) -->
    <title>
        <band height="70">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="60" backcolor="#1565C0"/>
            </rectangle>
            <staticText>
                <reportElement x="0" y="5" width="535" height="30"
                               forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="16" isBold="true"/>
                </textElement>
                <text><![CDATA[VENTARÁPIDA — CIERRE DE CAJA DIARIO]]></text>
            </staticText>
            <textField>
                <reportElement x="0" y="35" width="535" height="20"
                               forecolor="#FFFFFF"/>
                <textElement textAlignment="Center">
                    <font size="11"/>
                </textElement>
                <textFieldExpression><![CDATA["Fecha: " + $P{FECHA} + "   |   Total de ventas: " + $P{CANT_VENTAS}]]></textFieldExpression>
            </textField>
        </band>
    </title>

    <!-- CABECERA DE COLUMNAS (se repite en cada pagina) -->
    <columnHeader>
        <band height="25">
            <rectangle>
                <reportElement x="0" y="0" width="535" height="25" backcolor="#E3F2FD"/>
            </rectangle>
            <staticText>
                <reportElement x="0"   y="5" width="80"  height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Serie]]></text>
            </staticText>
            <staticText>
                <reportElement x="80"  y="5" width="80"  height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Correlativo]]></text>
            </staticText>
            <staticText>
                <reportElement x="160" y="5" width="70"  height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Tipo]]></text>
            </staticText>
            <staticText>
                <reportElement x="230" y="5" width="180" height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Cliente]]></text>
            </staticText>
            <staticText>
                <reportElement x="410" y="5" width="60"  height="15"/>
                <textElement textAlignment="Right"><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Total S/]]></text>
            </staticText>
            <staticText>
                <reportElement x="470" y="5" width="65"  height="15"/>
                <textElement><font size="9" isBold="true"/></textElement>
                <text><![CDATA[Hora]]></text>
            </staticText>
        </band>
    </columnHeader>

    <!-- DETALLE (una fila por venta) -->
    <detail>
        <band height="20">
            <textField>
                <reportElement x="0"   y="2" width="80"  height="15"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{serie}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="80"  y="2" width="80"  height="15"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{correlativo}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="160" y="2" width="70"  height="15"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{tipoCompro}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="230" y="2" width="180" height="15"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{cliente}]]></textFieldExpression>
            </textField>
            <textField pattern="#,##0.00">
                <reportElement x="410" y="2" width="60"  height="15"/>
                <textElement textAlignment="Right"><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{total}]]></textFieldExpression>
            </textField>
            <textField>
                <reportElement x="470" y="2" width="65"  height="15"/>
                <textElement><font size="9"/></textElement>
                <textFieldExpression><![CDATA[$F{hora}]]></textFieldExpression>
            </textField>
        </band>
    </detail>

    <!-- RESUMEN (al final del reporte) -->
    <summary>
        <band height="50">
            <line>
                <reportElement x="0" y="5" width="535" height="1"/>
            </line>
            <staticText>
                <reportElement x="310" y="15" width="100" height="20"/>
                <textElement textAlignment="Right">
                    <font size="11" isBold="true"/>
                </textElement>
                <text><![CDATA[TOTAL DEL DÍA:]]></text>
            </staticText>
            <textField pattern="S/ #,##0.00">
                <reportElement x="410" y="15" width="125" height="20"
                               forecolor="#1565C0"/>
                <textElement textAlignment="Right">
                    <font size="13" isBold="true"/>
                </textElement>
                <textFieldExpression><![CDATA[$P{TOTAL_DIA}]]></textFieldExpression>
            </textField>
        </band>
    </summary>

</jasperReport>
